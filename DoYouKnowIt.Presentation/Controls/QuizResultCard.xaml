<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoYouKnowIt.Presentation.Controls.QuizResultCard"
             x:Name="Root"
             Loaded="OnLoadedQuizResultCard">
             <!--On Loaded Update Background color depending IsCorrect value-->
        <Grid>
            <Border 
                x:Name="QuizResultCardBox"
                HorizontalOptions="Center"
                StrokeShape="RoundRectangle 10"
                BackgroundColor="{StaticResource ItemBackground}" 
                Stroke="{StaticResource ItemBorder}"
                StrokeThickness="1.5"
                Padding="20">
                <HorizontalStackLayout Spacing="50" HorizontalOptions="Center">
                    <VerticalStackLayout 
                        WidthRequest="500"
                        Spacing="5">
                        <Label TextColor="White" FontSize="20" Text="{Binding IsCorrect, StringFormat='Was correct? {0}', Source={x:Reference Root}}"/>
                        <Label TextColor="White" FontSize="20" Text="{Binding RoundScore, StringFormat='Points: {0}', Source={x:Reference Root}}"/>
                        <Border Margin="0, 10"></Border>
                        <Label TextColor="White" FontSize="20" Text="{Binding QuestionText, StringFormat='Q: {0}',Source={x:Reference Root}}"/>
                        <Label TextColor="White" FontSize="20" Text="{Binding CorrectAnswersText, StringFormat='A: {0}', Source={x:Reference Root}}"/>
                        <Border Margin="0, 10"></Border>
                        <Label TextColor="White" FontSize="20" Text="{Binding SelectedAnswerText, StringFormat='Your answer: {0}', Source={x:Reference Root}}"/>
                    </VerticalStackLayout>

                    <Border 
                        HorizontalOptions="Center"
                        StrokeShape="RoundRectangle 10"
                        BackgroundColor="White"
                        StrokeThickness="2"
                        Stroke="Black"
                        MaximumWidthRequest="400"
                        HeightRequest="225">
                        <Image
                            Source="{Binding QuestionImageUrl}"
                            Aspect="AspectFill"
                            BackgroundColor="White"/>
                    </Border>

                </HorizontalStackLayout>
            </Border>
        </Grid>
</ContentView>
