<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoYouKnowIt.Presentation.Controls.NavBlockButton"
             x:Name="Root">
    
    <VerticalStackLayout x:Name="MyObject">
        <Border
         Margin="5"
         StrokeShape="RoundRectangle 5">

            <Border.Shadow>
                <Shadow
                 Offset="4,4"
                 Radius="5"
                 Opacity="0.4"/>
            </Border.Shadow>

            <Border.Background> <!--Gradient background-->
                <LinearGradientBrush StartPoint="0,1" EndPoint="1,0">
                    <GradientStop Color="{StaticResource QCardDark}" Offset="0.3" />
                    <GradientStop Color="{StaticResource QCardLight}" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>

            <Button 
                Padding="70"
                BackgroundColor="Transparent"
                Text="{Binding ButtonText,         Source={x:Reference Root}}"
                TextColor="White"
                FontSize="50"
                Command="{Binding ButtonCommand,   Source={x:Reference Root}}"
                Pressed="OnButtonPressed"
                Released="OnButtonReleased">
            </Button>

        </Border>

    </VerticalStackLayout>
</ContentView>
