<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoYouKnowIt.Presentation.Controls.QuizCardControl"
             x:Name="Root">
             
    <VerticalStackLayout>
        <Border
        BackgroundColor="{StaticResource ItemBackground}"
        Stroke="{StaticResource ItemBorder}"
        StrokeShape="RoundRectangle 5">
            <HorizontalStackLayout 
            Spacing="15"
            Padding="5">

                <Border
                StrokeShape="RoundRectangle 10">
                    <Image
                    Source="{Binding QuizImageUrl, Source={x:Reference Root}}"
                    WidthRequest="80"
                    HeightRequest="80"
                    BackgroundColor="White"/>
                </Border>

                <VerticalStackLayout
            VerticalOptions="Center">
                    <Label
                    Text="{Binding QuizTitle, Source={x:Reference Root}}"
                    FontSize="20"
                    TextColor="White"/>
                    <Label
                    Text="{Binding QuizDescription, Source={x:Reference Root}}"
                    TextColor="White"/>
                </VerticalStackLayout>

            </HorizontalStackLayout>
        </Border>






    </VerticalStackLayout>
</ContentView>
