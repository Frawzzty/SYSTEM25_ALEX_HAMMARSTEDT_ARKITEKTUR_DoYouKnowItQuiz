<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->
    
    <Color x:Key="BgDefault">#ACD2E6</Color>

    <!--Buttons-->
    <Color x:Key="BtnNavigation">#3B8CB8</Color>
    <Color x:Key="BtnBlue">#5A92D1</Color>
    <Color x:Key="BtnRed">#D15A5A</Color>
    <Color x:Key="BtnGreen">#65D14B</Color>

    
    <!--Items / QuizCards-->
    <Color x:Key="ItemBackground">#4B7F99</Color>
    <Color x:Key="ItemBorder">#3C677A</Color>

    <!--Items / GRADIENT-->
    <Color x:Key="QCardDark">#3C687A</Color>
    <Color x:Key="QCardLight">#5495B8</Color>


    <SolidColorBrush x:Key="MyBrush" Color="{StaticResource Primary}"/>

</ResourceDictionary>