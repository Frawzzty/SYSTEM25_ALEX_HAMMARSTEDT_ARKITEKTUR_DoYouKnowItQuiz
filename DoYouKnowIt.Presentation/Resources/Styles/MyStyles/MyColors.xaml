<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Note: For Android please see also Platforms\Android\Resources\values\colors.xml -->
    
    <Color x:Key="BgDefault">#ACD2E6</Color>

    <!--Buttons-->
    <Color x:Key="BtnNavigation">#3B8CB8</Color>
    <Color x:Key="BtnBlue">#5A92D1</Color>
    <Color x:Key="BtnRed">#D15A5A</Color>
    <Color x:Key="BtnGreen">#5DA64C</Color>

    
    <!--Items / QuizCards-->
    <Color x:Key="ItemBackground">#4B7F99</Color>
    <Color x:Key="ItemBorder">#305463</Color>

    <!--Items / GRADIENT-->
    <Color x:Key="QCardDark">#6FA2BF</Color>
    <Color x:Key="QCardLight">#5DB39D</Color>


    <SolidColorBrush x:Key="MyBrush999" Color="{StaticResource Primary}"/>

    <LinearGradientBrush x:Key="BgDefaultGradient">
        <GradientStop Color="#A3D1E6" Offset="0.0" />
        <GradientStop Color="#8ED3E8" Offset="1.0" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="QuizCardGradient">
        <GradientStop Color="#416E85" Offset="0.0" />
        <GradientStop Color="#4B7F99" Offset="1.0" />
    </LinearGradientBrush>

</ResourceDictionary>