<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DoYouKnowIt.Presentation.Controls"
             x:Class="DoYouKnowIt.Presentation.Views.QB.QBSelectPage"
             Title="Quiz Builder - Select"
             BackgroundColor="{StaticResource BgDefault}">
    <ScrollView>
        <VerticalStackLayout 
            Margin="25"
            Spacing="10">


            <HorizontalStackLayout Spacing="10">
                <!--Button, Back-->
                <controls:BackButton
            HorizontalOptions="Start"/>
                <!--Button, Add new Quiz-->
                <Button
                    Text="Add new Quiz"
                    Command="{Binding AddNewQuizCommand}"
                    Style="{StaticResource BtnGreen}"
                    HorizontalOptions="Start"/>
            </HorizontalStackLayout>



            <Label
                Text="Select to edit"
                TextColor="White"
                FontSize="25"
                FontAttributes="Bold"
                Margin="0,20,0,0"/>

            <!--Select Quiz, go edit page-->
            <CollectionView
                ItemsSource="{Binding Quizzes}"
                SelectedItem="{Binding SelectedQuiz}"
                SelectionMode="Single">
                <CollectionView.ItemTemplate>
                    <DataTemplate>

                        <controls:QuizCardControl
                            Padding="5"
                            QuizTitle="{Binding Title}"
                            QuizDescription="{Binding Description}"
                            QuizImageUrl="{Binding ImageUrl}"/>

                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
    
</ContentPage>