<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoYouKnowIt.Presentation.Views.QB.QBEditQuestionPage"
             Title="QBEditQuestionAsync">
    <VerticalStackLayout Spacing="10">
        <Entry
            Text="{Binding QuestionText}"
            Placeholder="Question text..."/>

        <Entry
            Text="{Binding QuestionImageUrl}"
            Placeholder="Question imageURL..."/>

        <Button
            Text="Save question"
            Command="{Binding SaveQuestionCommand}"/>

        <Button
            Text="Delete Question"
            Command="{Binding DeleteQuestionCommand}"/>


        <Button
            Text="Add new answer"/>
        <Label
            Text="Edit answers"/>
        <CollectionView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout
                        BackgroundColor="Black">
                        
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            
        </CollectionView>

    </VerticalStackLayout>
</ContentPage>