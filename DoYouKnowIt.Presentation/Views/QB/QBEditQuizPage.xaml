<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoYouKnowIt.Presentation.Views.QB.QBEditQuizPage"
             Title="Quiz Builder - Edit Quiz"
             BackgroundColor="{StaticResource BgDefault}">
    <VerticalStackLayout 
        Margin="25"
        Spacing="10">
        <Entry
            Placeholder="Quiz Title..."
            Text="{Binding QuizTitle}"
            Style="{StaticResource EntryDefault}"/>

        <Entry
            Placeholder="Quiz Description..."
            Text="{Binding QuizDescription}"
            Style="{StaticResource EntryDefault}"/>

        <Entry
            Placeholder="Quiz ImageUrl..."
            Text="{Binding QuizImageUrl}"
            Style="{StaticResource EntryDefault}"/>

        <Button
            Text="Save"
            Command="{Binding SaveQuizCommand}"
            Style="{StaticResource BtnGreen}"
            HorizontalOptions="Start"/>

        <Button
            Text="Add new Question"
            Command="{Binding AddNewQuestionCommand}"
            Style="{StaticResource BtnNavigation}"
            HorizontalOptions="Start"/>
        
        <Button
            Text="Delete Quiz"
            Command="{Binding DeleteQuizCommand}"
            Style="{StaticResource BtnRed}"
            HorizontalOptions="Start"/>

        <CollectionView
            ItemsSource="{Binding Questions}"
            SelectedItem="{Binding SelectedQuestion}"
            SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <HorizontalStackLayout
                        VerticalOptions="Center">
                        <Label
                            Text="{Binding QuestionText}"
                            FontSize="25"/>
                    </HorizontalStackLayout>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>