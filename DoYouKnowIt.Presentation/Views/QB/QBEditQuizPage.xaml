<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoYouKnowIt.Presentation.Views.QB.QBEditQuizPage"
             Title="QbEditQuizPage">
    <VerticalStackLayout>
        <Entry
            Placeholder="Quiz Title..."
            Text="{Binding QuizTitle}"/>

        <Entry
            Placeholder="Quiz Description..."
            Text="{Binding QuizDescription}"/>

        <Entry
            Placeholder="Quiz ImageUrl..."
            Text="{Binding QuizImageUrl}"/>

        <Button
            Text="Save"
            Command="{Binding SaveQuizAsyncCommand}"/>

        <Button
            Text="Add new Question"
            Command="{Binding EditQuestionAsyncCommand}"/>
        
        <Button
            Text="Delete Quiz"
            Command="{Binding DeleteQuizCommand}"/>

        <CollectionView
            ItemsSource="{Binding Questions}"
            SelectionMode="Single">
            <CollectionView.ItemTemplate>
                <DataTemplate>

                    <HorizontalStackLayout
                        VerticalOptions="Center">
                        <Label
                            Text="{Binding QuestionText}"
                            FontSize="25"/>
                    </HorizontalStackLayout>

                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>