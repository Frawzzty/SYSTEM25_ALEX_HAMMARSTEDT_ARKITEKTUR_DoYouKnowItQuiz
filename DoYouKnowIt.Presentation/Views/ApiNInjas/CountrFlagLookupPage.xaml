<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoYouKnowIt.Presentation.Views.ApiNInjas.CountrFlagLookupPage"
             Title="CountrFlagLookupPage"
             BackgroundColor="{StaticResource BgDefault}">
    <VerticalStackLayout
            HorizontalOptions="Center"
            Margin="25"
            Spacing="25">

        <!--No dedicated viewmodel for this page, only codebehind  - Will remove after -->
        <Label
           Text="&lt;Image> wont display .SVG images"
           />

        <HorizontalStackLayout Spacing="20">
            <Entry WidthRequest="200"
            Text="{Binding CountryIso2}"
            Placeholder="country iso2..."
            Style="{StaticResource EntryDefault}"
            />

            <Button
            Text="Get country"
            Clicked="OnClickedGetCountry"
            Style="{StaticResource BtnBlue}"/>
        </HorizontalStackLayout>

        <Label
            Text="{Binding ImageSquareUrl}"
            />
        <Label
            Text="{Binding ImageRectangleUrl}"
            />

        <Button
            Text="Go Back"
            Clicked="OnClickedGoBack"
            Style="{StaticResource BtnNavigation}"/>
    </VerticalStackLayout>
</ContentPage>