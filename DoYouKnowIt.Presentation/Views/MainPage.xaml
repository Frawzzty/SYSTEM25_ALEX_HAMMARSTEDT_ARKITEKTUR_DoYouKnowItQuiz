<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:controls="clr-namespace:DoYouKnowIt.Presentation.Controls"
             x:Class="DoYouKnowIt.Presentation.MainPage"
             BackgroundColor="{StaticResource BgDefault}">

    <ScrollView>
        <VerticalStackLayout
            HorizontalOptions="Center"
            Margin="25"
            Spacing="25">

            <Image
                x:Name="ImageLogo"
                Source="logo_main_transparent.png"
                HeightRequest="300"/>

            <HorizontalStackLayout 
                Spacing="10"
                HorizontalOptions="Center">
                <Entry 
                    WidthRequest="150"
                    Text="{Binding Username}"
                    Placeholder="username..."
                    Style="{StaticResource EntryDefault}"/>
                <Entry 
                    WidthRequest="150"
                    Text="{Binding Password}"
                    Placeholder="password..."
                    Style="{StaticResource EntryDefault}"/>
                <Button 
                    Text="Login"
                    Style="{StaticResource  BtnBlue}"
                    Command="{Binding LoginCommand}"
                    WidthRequest="80"/>
                
            </HorizontalStackLayout>
            <FlexLayout
                Direction="Row"
                Wrap="Wrap"
                AlignItems="Center"
                JustifyContent="Center">

                <controls:NavBlockButton
                    ButtonText="Play"
                    ButtonCommand="{Binding GoPlayPageCommand}"/>

                <controls:NavBlockButton
                    ButtonText="Leaderboard"
                    ButtonCommand="{Binding GoLeaderboardPageCommand}"/>

                <controls:NavBlockButton
                    ButtonText="Profile"
                    ButtonCommand="{Binding GoProfilePageCommand}"/>

                <controls:NavBlockButton
                    ButtonText="Quiz builder"
                    ButtonCommand="{Binding GoQuizBuilderPageCommand}"/>

                <controls:NavBlockButton
                    ButtonText="Country Flags"
                    ButtonCommand="{Binding GoCountryFlagLookupPageCommand}"/>

            </FlexLayout>
            
            



        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
