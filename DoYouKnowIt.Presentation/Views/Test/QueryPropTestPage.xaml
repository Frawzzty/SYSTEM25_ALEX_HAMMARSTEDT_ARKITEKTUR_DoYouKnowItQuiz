<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="DoYouKnowIt.Presentation.Views.Test.QueryPropTestPage"
             Title="QueryPropTestPage">
    <VerticalStackLayout>
        <Label 
            Text="{Binding QuizId}"
            FontSize="40"
            VerticalOptions="Start"/>
        <Label 
            Text="{Binding Quiz.Title}"
            FontSize="40"
            VerticalOptions="Start"/>
        <Label 
            Text="{Binding Quiz.Description}"
            FontSize="40"
            VerticalOptions="Start"/>
        <Label 
            Text="{Binding Quiz.ImageUrl}"
            FontSize="40"
            VerticalOptions="Start"/>

    </VerticalStackLayout>
</ContentPage>